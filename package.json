{
  "name": "dataread",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc -b",
    "build": "tsc -b && vite build",
    "prerender": "node scripts/prerender.mjs",
    "build:site": "npm run build && npm run prerender",
    "test": "node scripts/run-tests.mjs",
    "test:boot": "node scripts/boot-smoke.mjs",
    "test:e2e-lp": "node scripts/e2e-lp-serve.mjs",
    "prices:check": "node scripts/dump-prices.mjs",
    "deploy": "npm run build:site && firebase deploy --only hosting,firestore:rules",
    "deploy:functions": "firebase deploy --only functions"
  },
  "dependencies": {
    "firebase": "^12.14.0",
    "i18next": "^23.16.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^14.1.3",
    "react-router-dom": "^7.1.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "playwright": "^1.60.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.3"
  }
}
