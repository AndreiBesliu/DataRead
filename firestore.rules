rules_version = '2';

// DataRead — reguli Firestore. Principiu: izolare multi-tenant strictă — datele unui client stau
// sub clients/{uid}/** (owner-only); adminul intră doar prin claim; orice altceva e refuzat
// implicit. Blocurile noi se adaugă pe măsură ce fazele avansează (auth, onboarding, admin, Stripe).
service cloud.firestore {
  match /databases/{database}/documents {

    // Rapoarte de crash (consent-gated, trimise de client): create-only, validate strict —
    // nimeni nu le poate citi/modifica din client (se citesc doar din consolă/Admin SDK).
    match /errorReports/{id} {
      allow read, update, delete: if false;
      allow create: if request.resource.data.keys().hasOnly(
          ['name', 'message', 'stack', 'kind', 'version', 'build', 'userAgent', 'lang', 'at']
        )
        && request.resource.data.name is string && request.resource.data.name.size() <= 80
        && request.resource.data.message is string && request.resource.data.message.size() <= 300
        && request.resource.data.stack is string && request.resource.data.stack.size() <= 600
        && request.resource.data.kind is string && request.resource.data.kind.size() <= 40
        && request.resource.data.version is string && request.resource.data.version.size() <= 40
        && request.resource.data.build is string && request.resource.data.build.size() <= 40
        && request.resource.data.userAgent is string && request.resource.data.userAgent.size() <= 200
        && request.resource.data.lang is string && request.resource.data.lang.size() <= 20
        && request.resource.data.at == request.time;
    }
  }
}
