rules_version = '2';

// DataRead — reguli Firestore. Principiu: izolare multi-tenant strictă — datele unui client stau
// sub clients/{uid}/** (owner-only); adminul intră doar prin claim; orice altceva e refuzat
// implicit. Blocurile noi se adaugă pe măsură ce fazele avansează (auth, onboarding, admin, Stripe).
service cloud.firestore {
  match /databases/{database}/documents {

    function signedInAs(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // Adminii (operatorii platformei) — claim setat de functions/onAdminWrite pe baza
    // documentului admins/{uid} (creat doar din consolă/Admin SDK).
    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    match /admins/{uid} {
      allow read: if signedInAs(uid) || isAdmin();
      // TOATE mutațiile trec prin callable-ul owner-only `manageAdmin` (Admin SDK ocolește rules) +
      // bootstrap-ul. Clientul NU scrie direct (altfel orice admin ar putea scoate owner-ul/pe sine).
      allow create, update, delete: if false;
    }

    // Cererile de acces la backend: orice cont logat care încearcă /admin își înregistrează
    // cererea (o singură dată, pe propriul uid). Rezolvarea (approve/reject) = prin manageAdmin.
    match /adminRequests/{uid} {
      allow read: if signedInAs(uid) || isAdmin();
      allow create: if signedInAs(uid)
        && request.resource.data.keys().hasOnly(['email', 'displayName', 'requestedAt', 'status'])
        && request.resource.data.status == 'pending'
        && request.resource.data.email is string && request.resource.data.email.size() <= 120
        && request.resource.data.displayName is string && request.resource.data.displayName.size() <= 80
        && request.resource.data.requestedAt == request.time;
      allow update, delete: if false; // doar functions (manageAdmin / recomputeAdminClaim)
    }

    // Jurnal de audit al acțiunilor de administrare (append-only, scris doar de manageAdmin).
    match /adminAudit/{id} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // Lead-urile formularului public /start — site-ul NU are login, deci crearea e anonimă,
    // dar strict validată (whitelist + plafoane + status forțat 'new'). Doar adminii citesc.
    match /leads/{id} {
      allow read, update, delete: if isAdmin();
      allow create: if request.resource.data.keys().hasOnly(
          ['schema', 'companyName', 'cui', 'website', 'contactName', 'contactEmail', 'contactPhone',
           'industry', 'industryOther', 'objectives', 'adBudget', 'facebook', 'instagram', 'tiktok',
           'description', 'packageInterest', 'locale', 'status', 'createdAt']
        )
        && request.resource.data.schema == 1
        && request.resource.data.status == 'new'
        && request.resource.data.createdAt == request.time
        && request.resource.data.companyName is string && request.resource.data.companyName.size() <= 120
        && request.resource.data.contactEmail is string && request.resource.data.contactEmail.size() <= 120
        && request.resource.data.contactPhone is string && request.resource.data.contactPhone.size() <= 30
        && request.resource.data.description is string && request.resource.data.description.size() <= 2000
        && request.resource.data.objectives is list && request.resource.data.objectives.size() <= 5;

      // Cererile de marketing ale lead-ului (Verticala 1) — exclusiv zona operatorilor.
      match /requests/{reqId} {
        allow read, create, update, delete: if isAdmin();

        // Istoricul versiunilor de livrabile (snapshot-uri imutabile — fără update).
        match /versions/{versionId} {
          allow read, create, delete: if isAdmin();
          allow update: if false;
        }
      }
    }

    // ───────── Izolare multi-tenant: tot ce aparține unui client stă sub clients/{uid}/** ─────────
    // Owner-only pentru client; adminii pot CITI (panoul intern), dar nu scriu în v1.

    match /clients/{uid} {
      allow read: if signedInAs(uid) || isAdmin();
      // Crearea: doar schema curentă, fără câmpuri străine și NICIODATĂ entitlement
      // (entitlement-ul e scris exclusiv de Cloud Functions, ca mirror din Stripe).
      allow create: if signedInAs(uid)
        && request.resource.data.keys().hasOnly(
          ['schema', 'email', 'displayName', 'locale', 'onboardingStatus', 'createdAt', 'tosAcceptedAt']
        )
        && request.resource.data.schema == 1
        && request.resource.data.onboardingStatus in ['none', 'submitted'];
      // Update: clientul poate atinge DOAR câmpurile proprii (whitelist) — NICIODATĂ entitlement sau
      // câmpuri oglindite de functions (ex. marketingReport, citit de portal ȘI de operatori). Fără
      // whitelist, un client își putea falsifica raportul / injecta date arbitrare în doc-ul citit de admin.
      allow update: if signedInAs(uid)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(
          ['email', 'displayName', 'locale', 'onboardingStatus', 'tosAcceptedAt']
        )
        && request.resource.data.schema == 1;
      allow delete: if false;

      // Livrabilele client-safe (oglindite de functions, FĂRĂ note interne) — clientul le citește.
      match /deliverables/{reqId} {
        allow read: if signedInAs(uid) || isAdmin();
        allow write: if false; // doar functions (Admin SDK)
        // Istoricul de versiuni (read-only) — oglindit client-safe de onRequestVersionCreated.
        match /versions/{versionId} {
          allow read: if signedInAs(uid) || isAdmin();
          allow write: if false; // doar functions (Admin SDK)
        }
      }

      // Index de descoperire a LP-urilor clientului (oglindit de onLandingPageWrite, DOAR câmpuri
      // publice slug/title/publicUrl/status) — clientul își enumeră paginile fără a citi doc-ul intern.
      match /lpIndex/{slug} {
        allow read: if signedInAs(uid) || isAdmin();
        allow write: if false; // doar functions (Admin SDK)
      }

      // Mini-CRM al clientului pe lead-urile LP (status + notă), SEPARAT de submissions (pipeline-ul
      // agenției). Deținut + scris de client (owner-only). Cheia = submissionId (anotare privată).
      match /lpLeadState/{id} {
        allow read: if signedInAs(uid) || isAdmin();
        allow create, update: if signedInAs(uid)
          && request.resource.data.keys().hasOnly(['schema', 'status', 'note', 'slug', 'updatedAt'])
          && request.resource.data.schema == 1
          && request.resource.data.status in ['nou', 'contactat', 'calificat', 'castigat', 'pierdut']
          && request.resource.data.note is string && request.resource.data.note.size() <= 1000
          && request.resource.data.slug is string && request.resource.data.slug.size() <= 60
          && request.resource.data.updatedAt == request.time;
        allow delete: if signedInAs(uid);
      }

      // Notificări + task-uri generate de automatizările client-scope (scope:'client'). Scrise EXCLUSIV de motor
      // (Admin SDK). Clientul își vede DOAR pe ale lui (izolare multi-tenant); poate marca un task ca rezolvat.
      match /notifications/{id} {
        allow read: if signedInAs(uid) || isAdmin();
        allow write: if false;
      }
      match /tasks/{id} {
        allow read: if signedInAs(uid) || isAdmin();
        allow create, delete: if false; // doar motorul (Admin SDK)
        allow update: if (signedInAs(uid) || isAdmin())
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])
          && request.resource.data.status in ['open', 'done'];
      }

      // Facturi / Proforme (Verticala 2, modul crm) — create/editate de operatori; clientul le CITEȘTE (read owner).
      match /invoices/{id} {
        allow read: if signedInAs(uid) || isAdmin();
        allow create, update: if isAdmin()
          && request.resource.data.schema == 1
          && request.resource.data.kind in ['proforma', 'factura']
          && request.resource.data.status in ['draft', 'sent', 'paid', 'cancelled']
          && request.resource.data.vatRate is number
          && request.resource.data.vatRate >= 0 && request.resource.data.vatRate <= 100
          && request.resource.data.items is list && request.resource.data.items.size() <= 50
          && request.resource.data.seller is map && request.resource.data.buyer is map
          && request.resource.data.currency is string && request.resource.data.currency.size() <= 8;
        allow delete: if isAdmin();
      }

      match /onboarding/{docId} {
        allow read: if signedInAs(uid) || isAdmin();
        allow create, update: if signedInAs(uid)
          && docId == 'main'
          && request.resource.data.keys().hasOnly(
            ['schema', 'companyName', 'cui', 'website', 'contactName', 'contactEmail', 'contactPhone',
             'industry', 'industryOther', 'objectives', 'adBudget', 'facebook', 'instagram', 'tiktok',
             'description', 'packageInterest', 'locale', 'submittedAt', 'updatedAt']
          )
          && request.resource.data.schema == 1
          && request.resource.data.companyName is string && request.resource.data.companyName.size() <= 120
          && request.resource.data.description is string && request.resource.data.description.size() <= 2000
          && request.resource.data.objectives is list && request.resource.data.objectives.size() <= 5;
        allow delete: if false;
      }

      // „Self Marketing" (felia self-serve): profilul firmei (scris de client) + strategia generată +
      // quota de trial (scrise DOAR de functions, Admin SDK). Clientul își citește toate doc-urile.
      match /selfMarketing/{docId} {
        allow read: if signedInAs(uid) || isAdmin();
        // DOAR 'profile' e scris de client (whitelist strict + plafoane + schema). 'strategy'/'quota'
        // cad pe write:false → scrise exclusiv de functions; clientul nu-și poate falsifica strategia/quota.
        allow create, update: if signedInAs(uid)
          && docId == 'profile'
          && request.resource.data.keys().hasOnly(
            ['schema', 'companyName', 'industry', 'industryOther', 'productsServices',
             'audience', 'area', 'competitors', 'budget', 'goals', 'locale', 'updatedAt']
          )
          && request.resource.data.schema == 1
          && request.resource.data.companyName is string && request.resource.data.companyName.size() <= 120
          && request.resource.data.industry is string && request.resource.data.industry.size() <= 40
          && request.resource.data.industryOther is string && request.resource.data.industryOther.size() <= 80
          && request.resource.data.productsServices is string && request.resource.data.productsServices.size() <= 2000
          && request.resource.data.audience is string && request.resource.data.audience.size() <= 1000
          && request.resource.data.area is string && request.resource.data.area.size() <= 200
          && request.resource.data.competitors is string && request.resource.data.competitors.size() <= 1000
          && request.resource.data.budget is string && request.resource.data.budget.size() <= 200
          && request.resource.data.goals is string && request.resource.data.goals.size() <= 2000
          && request.resource.data.locale in ['ro', 'en']
          && request.resource.data.updatedAt == request.time;
        allow delete: if false;
      }

      // Credențiale de platformă (Meta/Google/TikTok Ads) pentru conectorii de ingestie automată.
      // Doc-ul conține un token de acces CRIPTAT (AES-256-GCM) → read ADMIN-ONLY (NU owner): token-ul nu
      // ajunge NICIODATĂ la client. Scris/citit EXCLUSIV de functions (Admin SDK, ocolește rules);
      // OAuth-ul e admin-gated (operatorul conectează contul clientului). Vezi docs/CONNECTORS-ADS-API.md.
      match /platformCredentials/{platform} {
        allow read: if isAdmin();
        allow write: if false;
      }
    }

    // Contoarele de generări AI (scrise doar de functions prin Admin SDK) — adminii le pot citi
    // pentru statisticile din panou.
    match /aiUsage/{uid} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // Configurarea publică a site-ului: tema (publicTheme) + chrome-ul global header/footer (publicChrome).
    // PUBLIC-READ (site-ul + scriptul de coacere o citesc; e cosmetică, nu date sensibile); scriere DOAR de
    // admini, validată + plafonată. Fiecare doc are payload-ul lui (theme is map / chrome is map).
    match /siteConfig/{docId} {
      allow read: if true;
      allow create, update: if isAdmin()
        && docId in ['publicTheme', 'publicChrome']
        && request.resource.data.keys().hasOnly(['schema', 'theme', 'chrome', 'updatedAt', 'updatedBy'])
        && request.resource.data.schema == 1
        && (docId != 'publicTheme' || request.resource.data.theme is map)
        && (docId != 'publicChrome' || request.resource.data.chrome is map)
        && request.resource.data.updatedAt == request.time;
      allow delete: if false;
    }

    // Marketing Center: campaniile (colecție de nivel superior, cu leadId) + metricile zilnice.
    // Exclusiv zona operatorilor. Conectorii Meta/Google Ads API vor scrie tot aici, prin
    // Admin SDK (ocolește rules) — vezi docs/CONNECTORS-ADS-API.md.
    // Portal client (multi-tenant): clientul logat citește DOAR campaniile lui (clientUid == uid).
    // Scrierea rămâne exclusiv a operatorilor. Metricile moștenesc accesul prin campania-părinte.
    match /campaigns/{campaignId} {
      allow read: if isAdmin() || (request.auth != null && resource.data.clientUid == request.auth.uid);
      allow create, update, delete: if isAdmin();
      match /metrics/{date} {
        allow read: if isAdmin() ||
          (request.auth != null &&
           get(/databases/$(database)/documents/campaigns/$(campaignId)).data.clientUid == request.auth.uid);
        allow create, update, delete: if isAdmin();
      }
    }

    // ───────── Motor de automatizare (declanșatoare → condiții → acțiuni) ─────────
    // O REGULĂ = automations/{id}; jurnalul de rulări = automations/{id}/runs/{runId} (audit + dedupe idempotent).
    // Regulile sunt deținute de operatori (scope:'agency') SAU de client (scope:'client', per clientUid — Verticala 2).
    // Mutațiile trec EXCLUSIV prin callable-uri (validare + cote + anti-buclă server-side) ⇒ write:false aici
    // (Admin SDK ocolește rules). Citire: admin, plus clientul își vede DOAR regulile lui de scope 'client'.
    match /automations/{autoId} {
      allow read: if isAdmin()
        || (request.auth != null && resource.data.scope == 'client' && resource.data.clientUid == request.auth.uid);
      allow write: if false;
      match /runs/{runId} {
        allow read: if isAdmin()
          || (request.auth != null
              && get(/databases/$(database)/documents/automations/$(autoId)).data.scope == 'client'
              && get(/databases/$(database)/documents/automations/$(autoId)).data.clientUid == request.auth.uid);
        allow write: if false;
      }
      // Contoare backstop orar (anti-runaway) — scrise EXCLUSIV de motor (Admin SDK).
      match /rate/{rid} {
        allow read: if isAdmin();
        allow write: if false;
      }
    }

    // Notificări produse de motorul de automatizare (acțiunea notify.operator). Zona operatorilor; scrise EXCLUSIV
    // de functions (Admin SDK). Read admin-only (pot conține context intern de campanie/lead).
    match /notifications/{id} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // Task-uri operator generate de automatizări (acțiunea task.create). Create de motor (Admin SDK). Operatorii le
    // citesc + le pot închide/șterge (status open→done). Zona operatorilor.
    match /tasks/{id} {
      allow read: if isAdmin();
      allow create: if false; // doar motorul (Admin SDK)
      allow update, delete: if isAdmin();
    }

    // Config intern al platformei (zona operatorilor). Ex.: appConfig/automation = plafon zilnic AI + bypass entitlement
    // pentru acțiunile AI din automatizări. Read+write admin (setat din /admin); motorul îl citește prin Admin SDK.
    match /appConfig/{docId} {
      allow read: if isAdmin();
      allow write: if isAdmin() && request.resource.data.schema == 1 && (
        (docId == 'automation'
          && request.resource.data.aiDailyCap is int
          && request.resource.data.aiDailyCap >= 0 && request.resource.data.aiDailyCap <= 100000
          && request.resource.data.aiBypassEntitlement is bool)
        || (docId == 'invoiceSeller'
          && request.resource.data.seller is map
          && request.resource.data.defaultVatRate is number
          && request.resource.data.defaultVatRate >= 0 && request.resource.data.defaultVatRate <= 100
          && request.resource.data.defaultSeries is string && request.resource.data.defaultSeries.size() <= 20
          && request.resource.data.defaultCurrency is string && request.resource.data.defaultCurrency.size() <= 8)
      );
    }

    // ───────── Landing Pages (LP Studio) ─────────
    // Operatorii construiesc pagini publice de campanie (cod HTML + design). Doc ID = slug.
    // Pagina e servită de funcția serveLp (Admin SDK), dar permitem citirea publică a celor
    // PUBLICATE (defense-in-depth). Drafturile + scrierea = doar operatorii. Submission-urile și
    // telemetria se scriu EXCLUSIV prin functions (Admin SDK ocolește rules).
    match /landingPages/{slug} {
      // Doar adminii citesc doc-ul LP prin client SDK; publicul primește pagina prin serveLp (Admin SDK,
      // SSR). Citirea publică ar fi expus câmpuri interne (clientUid/leadId/projectId/form/knownVariants).
      allow read: if isAdmin();
      // request.resource.data e null la delete → validarea stă doar pe create/update.
      allow create, update: if isAdmin()
        && request.resource.data.schema == 1
        && request.resource.data.slug is string && request.resource.data.slug.size() <= 60
        && request.resource.data.title is string && request.resource.data.title.size() <= 140
        && request.resource.data.html is string && request.resource.data.html.size() <= 200000
        && request.resource.data.status in ['draft', 'published']
        // knownVariants (allowlist de variante de link) — opțional, dar dacă există: map plafonat (anti-bloat).
        && (!('knownVariants' in request.resource.data) || (request.resource.data.knownVariants is map && request.resource.data.knownVariants.size() <= 200))
        // SEO/social (opțional): URL-uri plafonate (anti-bloat; https validat în serveLp + coerce).
        && (!('ogImage' in request.resource.data) || (request.resource.data.ogImage is string && request.resource.data.ogImage.size() <= 500))
        && (!('favicon' in request.resource.data) || (request.resource.data.favicon is string && request.resource.data.favicon.size() <= 500))
        // kind: 'campaign' (LP, /p/) sau 'site' (pagină de site, /pagina/) — opțional (legacy fără kind = campaign).
        && (!('kind' in request.resource.data) || request.resource.data.kind in ['campaign', 'site'])
        // conversionHtml (sticky CTA + exit popup compilate) — opțional, plafonat (anti-bloat; injectat de serveLp).
        && (!('conversionHtml' in request.resource.data) || (request.resource.data.conversionHtml is string && request.resource.data.conversionHtml.size() <= 200000))
        // A/B testing: experimente (listă plafonată) + armsHtml (map). Garda de OCTEȚI (sumă html+arme ≤200KB)
        // rămâne în editor (regulile nu pot itera map-uri); admin-only write + limita Firestore 1MiB = backstop.
        && (!('experiments' in request.resource.data) || (request.resource.data.experiments is list && request.resource.data.experiments.size() <= 3))
        && (!('armsHtml' in request.resource.data) || request.resource.data.armsHtml is map);
      allow delete: if isAdmin();

      // Portal client: clientul logat citește submisiile/statisticile/variantele LP-urilor LUI
      // (LP.clientUid == uid), prin get() pe doc-ul părinte (ca la campaigns/metrics). Doc-ul
      // landingPages rămâne admin-only (câmpuri interne); unlink = instant (regula reevaluată).
      // submissions = LEAD-urile clientului (proprii) — vede doc-ul întreg, inclusiv ua/referrer/
      // geoCountry ale propriului prospect (date legitime de CRM). `visits` (telemetria brută a
      // ÎNTREGULUI trafic anonim, nu doar a lead-urilor) rămâne admin-only mai jos.
      match /submissions/{subId} {
        allow read: if isAdmin() || (request.auth != null && get(/databases/$(database)/documents/landingPages/$(slug)).data.clientUid == request.auth.uid);
        allow update, delete: if isAdmin();
        allow create: if false; // doar prin functions/submitLpForm (Admin SDK, validare completă)
      }
      match /visits/{visitId} {
        allow read: if isAdmin();
        allow write: if false; // doar functions (serveLp) — UA/IP brut, NU se expune clientului
      }
      match /stats/{date} {
        allow read: if isAdmin() || (request.auth != null && get(/databases/$(database)/documents/landingPages/$(slug)).data.clientUid == request.auth.uid);
        allow write: if false; // doar functions (rollup-uri incrementate server-side)
      }
      match /variants/{key} {
        allow read: if isAdmin() || (request.auth != null && get(/databases/$(database)/documents/landingPages/$(slug)).data.clientUid == request.auth.uid);
        allow write: if false; // doar functions (contoare incrementate server-side)
      }
      // A/B testing: contoare vizite/conversii per variantă-experiment (cheia = expId__armId). Aceeași izolare
      // multi-tenant ca stats/variants (client vede DOAR ale LP-ului lui); scrise exclusiv de functions.
      match /abStats/{key} {
        allow read: if isAdmin() || (request.auth != null && get(/databases/$(database)/documents/landingPages/$(slug)).data.clientUid == request.auth.uid);
        allow write: if false;
      }
      // Linkuri etichetate generate de operator (Link Builder). Scrise din client de admin.
      match /links/{id} {
        allow read, delete: if isAdmin();
        allow create, update: if isAdmin()
          && request.resource.data.keys().hasOnly(['schema', 'label', 'source', 'medium', 'campaign', 'content', 'term', 'url', 'variantKey', 'campaignId', 'createdAt', 'createdBy'])
          && request.resource.data.schema == 1
          && request.resource.data.label is string && request.resource.data.label.size() <= 80
          && request.resource.data.url is string && request.resource.data.url.size() <= 600
          && request.resource.data.variantKey is string && request.resource.data.variantKey.matches('^[a-z0-9~_-]{1,161}$')
          // campaignId (opțional) — leagă linkul de o campanie din Marketing Center pentru atribuire.
          && (!('campaignId' in request.resource.data) || (request.resource.data.campaignId is string && request.resource.data.campaignId.size() <= 128));
      }
    }

    // Proiecte LP (organizare) — colecție gestionată de admin.
    match /lpProjects/{id} {
      allow read: if isAdmin();
      allow create, update: if isAdmin()
        && request.resource.data.keys().hasOnly(['schema', 'name', 'color', 'clientUid', 'createdAt', 'createdBy'])
        && request.resource.data.schema == 1
        && request.resource.data.name is string && request.resource.data.name.size() <= 60
        && request.resource.data.color is string && request.resource.data.color.size() <= 9
        && (!('clientUid' in request.resource.data) || (request.resource.data.clientUid is string && request.resource.data.clientUid.size() <= 128));
      allow delete: if isAdmin();
    }

    // ───────── Stripe (extensia firestore-stripe-payments) ─────────
    // Extensia scrie cu Admin SDK (ocolește rules); clientul doar citește ce-i aparține și
    // creează checkout_sessions (extensia completează `url`).

    match /customers/{uid} {
      allow read: if signedInAs(uid) || isAdmin();
      allow write: if false;

      match /checkout_sessions/{id} {
        // Create rămâne permis: e tiparul cerut de extensia firestore-stripe-payments (clientul creează
        // sesiunea, extensia completează `url`); priceId-ul e validat server-side de extensie. App Check
        // (de activat înainte de lansarea plăților) e protecția corectă aici, nu blocarea create-ului.
        allow read, create: if signedInAs(uid);
        allow update, delete: if false;
      }
      match /subscriptions/{id} {
        allow read: if signedInAs(uid) || isAdmin();
        allow write: if false;
      }
      match /payments/{id} {
        allow read: if signedInAs(uid) || isAdmin();
        allow write: if false;
      }
    }

    // Catalogul sincronizat de extensie — public (pagina de pricing citește prețurile live).
    match /products/{id} {
      allow read: if true;
      allow write: if false;
      match /prices/{priceId} {
        allow read: if true;
        allow write: if false;
      }
      match /tax_rates/{taxId} {
        allow read: if true;
        allow write: if false;
      }
    }
    // collectionGroup peste prices — calea preferată din billing.fetchLivePrices (prinde și
    // prețurile cu părinte-fantomă, lecție CNCVS).
    match /{path=**}/prices/{priceId} {
      allow read: if true;
    }

    // Rapoarte de crash (consent-gated, trimise de client): create-only, validate strict —
    // nimeni nu le poate citi/modifica din client (se citesc doar din consolă/Admin SDK).
    match /errorReports/{id} {
      // Admin poate CITI rapoartele de crash (tab „Sănătate") — conțin doar nume/mesaj/stack/build, fără date de client.
      allow read: if isAdmin();
      allow update, delete: if false;
      allow create: if request.resource.data.keys().hasOnly(
          ['name', 'message', 'stack', 'kind', 'version', 'build', 'userAgent', 'lang', 'at']
        )
        && request.resource.data.name is string && request.resource.data.name.size() <= 80
        && request.resource.data.message is string && request.resource.data.message.size() <= 300
        && request.resource.data.stack is string && request.resource.data.stack.size() <= 600
        && request.resource.data.kind is string && request.resource.data.kind.size() <= 40
        && request.resource.data.version is string && request.resource.data.version.size() <= 40
        && request.resource.data.build is string && request.resource.data.build.size() <= 40
        && request.resource.data.userAgent is string && request.resource.data.userAgent.size() <= 200
        && request.resource.data.lang is string && request.resource.data.lang.size() <= 20
        && request.resource.data.at == request.time;
    }
  }
}
